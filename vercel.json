{
  "services": {
    "web": {
      "root": "apps/hyperlocalise-web",
      "framework": "nextjs",
      "buildCommand": "pnpm run db:migrate && pnpm build"
    },
    "cat_validate": {
      "runtime": "container",
      "root": ".",
      "entrypoint": "apps/cat-validate/Dockerfile.vercel"
    }
  },
  "rewrites": [
    {
      "source": "/api/cat-validate/:path*",
      "destination": {
        "service": "cat_validate",
        "path": "/:path*"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron/github-repository-automation-dispatch",
      "schedule": "*/15 * * * *"
    }
  ]
}
