# Copy to .env.worker and pass with:
# docker compose --env-file .env.worker -f docker-compose.gcp.yml --profile worker up

TRANSLATION_GCP_STORAGE_BUCKET=your-bucket
TRANSLATION_GCP_STORAGE_SIGNING_ACCOUNT=service-account@example.iam.gserviceaccount.com
TRANSLATION_GCP_STORAGE_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Pick one provider section.
TRANSLATION_LLM_PROVIDER=openai
TRANSLATION_LLM_MODEL=gpt-5.2
OPENAI_API_KEY=your-openai-api-key

# AZURE_OPENAI_BASE_URL=https://<resource>.openai.azure.com/openai/v1
# AZURE_OPENAI_API_KEY=your-azure-openai-api-key

# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_API_KEY=your-anthropic-api-key

# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_API_KEY=your-gemini-api-key
