go_test(
    name = "cmd_test",
    srcs = glob(["*_test.go"]),
    embed = [":cmd"],
    deps = [
        "//apps/cli/internal/i18n/evalsvc",
        "//apps/cli/internal/i18n/evalsvc/scoring",
        "//apps/cli/internal/i18n/runsvc",
