        "//apps/cli/internal/i18n/runsvc",
        "//apps/cli/internal/i18n/storage/bootstrap",
        "//apps/cli/internal/i18n/storageregistry",
        "//apps/cli/internal/i18n/syncsvc",
        "//apps/cli/internal/progressui",
        "//internal/i18n/storage",
        "//internal/i18n/translationfileparser",
        "//pkg/i18nconfig",
        "@com_github_charmbracelet_bubbles_v2//filepicker",
        "@com_github_charmbracelet_bubbles_v2//help",
        "@com_github_charmbracelet_bubbles_v2//key",
        "@com_github_charmbracelet_bubbles_v2//list",
        "@com_github_charmbracelet_bubbles_v2//paginator",
