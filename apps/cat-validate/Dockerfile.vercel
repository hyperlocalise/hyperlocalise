# syntax=docker/dockerfile:1

FROM golang:1.26.1-alpine AS builder
WORKDIR /src
RUN apk add --no-cache git ca-certificates

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /cat-validate ./apps/cat-validate

FROM gcr.io/distroless/static-debian12:nonroot
WORKDIR /
COPY --from=builder /cat-validate /cat-validate
EXPOSE 8080
USER nonroot:nonroot
ENTRYPOINT ["/cat-validate"]
