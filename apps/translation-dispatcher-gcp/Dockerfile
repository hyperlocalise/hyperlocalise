FROM debian:bookworm-slim

RUN groupadd -r appuser && useradd -r -g appuser appuser

WORKDIR /app

COPY bazel-bin/apps/translation-dispatcher-gcp/translation-dispatcher-gcp_/translation-dispatcher-gcp /app/translation-dispatcher-gcp

ENV TRANSLATION_QUEUE_DRIVER=stub
ENV TRANSLATION_GCP_PUBSUB_PROJECT_ID=
ENV TRANSLATION_GCP_PUBSUB_TOPIC=
ENV GOOGLE_APPLICATION_CREDENTIALS=
ENV TRANSLATION_DISPATCHER_POLL_INTERVAL=2s
ENV TRANSLATION_DISPATCHER_BATCH_SIZE=32
ENV TRANSLATION_DISPATCHER_LEASE_DURATION=30s
ENV TRANSLATION_DISPATCHER_MAX_ATTEMPTS=5
ENV TRANSLATION_DISPATCHER_INITIAL_BACKOFF=1s
ENV TRANSLATION_DISPATCHER_MAX_BACKOFF=30s

USER appuser
ENTRYPOINT ["/app/translation-dispatcher-gcp"]
