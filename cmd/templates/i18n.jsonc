{
  "locales": {
    // Base language your content is authored in.
    "source": "en-US",
    // Languages to generate translations for.
    "targets": [
      "es-ES",
      "fr-FR",
      "de-DE"
    ],
    "fallbacks": {
      // `{{source}}` is always the implicit base for fallbacks.
      // Example: if `fr-FR` is missing a key, try `es-ES` before `en-US`.
      "fr-FR": [
        "es-ES"
      ]
    }
  },
  // Buckets group reusable file mappings.
  // Use `{{source}}` and `{{target}}` placeholders in paths.
  "buckets": {
    "ui": {
      "files": [
        {
          // Translate from source locale file to each target locale file.
          "from": "content/ui/{{source}}/strings.json",
          "to": "dist/ui/{{target}}/strings.json"
        },
        {
          // Shared source file copied/rendered per target output.
          "from": "content/ui/shared.json",
          "to": "dist/ui/shared.{{target}}.json"
        }
      ]
    },
    "docs": {
      "files": [
        {
          "from": "content/docs/{{target}}/guide.md",
          "to": "dist/docs/{{target}}/guide.md"
        }
      ]
    }
  },
  "groups": {
    // A group selects which targets + buckets a rule applies to.
    // `targets` or `buckets` can be empty, but not both.
    "modern": {
      "targets": [
        "es-ES",
        "fr-FR"
      ],
      "buckets": [
        "ui"
      ]
    },
    "docs-team": {
      "targets": [
        "de-DE"
      ],
      "buckets": [
        "docs"
      ]
    }
  },
  "llm": {
    // Default profile is mandatory and sets the core provider/model/prompt.
    "profiles": {
      "default": {
        // Any provider supported by your CLI/runtime.
        "provider": "openai",
        // Model id for this profile.
        "model": "xmt-std",
        // Available vars: {{source}}, {{target}}, {{input}}.
        "prompt": "Translate from {{source}} to {{target}}:\n\n{{input}}"
      },
      "verbose": {
        "provider": "openai",
        "model": "xmt-std",
        "prompt": "Translate from {{source}} to {{target}} with richer context:\n\n{{input}}"
      },
      "precise": {
        "provider": "openai",
        "model": "xmt-std",
        "prompt": "Translate from {{source}} to {{target}} precisely:\n\n{{input}}"
      }
    },
    "rules": [
      {
        // Match group -> pick profile. Higher priority wins conflicts.
        "priority": 100,
        "group": "modern",
        "profile": "precise"
      },
      {
        // Keep priorities simple (e.g. 100, 50, 10).
        "priority": 50,
        "group": "docs-team",
        "profile": "verbose"
      }
    ]
  }
}
